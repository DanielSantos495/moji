{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moji",
  "version": "0.1.0",
  "identifier": "com.moji.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Moji",
        "width": 200,
        "height": 200,
        "minWidth": 100,
        "minHeight": 100,
        "maxWidth": 400,
        "maxHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "x": 1700,
        "y": 800,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
